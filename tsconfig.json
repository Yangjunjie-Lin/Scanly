{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "preserve",
    "incremental": true,
    "types": [
      "node"
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@scanly/scenario-schema": [
        "./packages/scenario-schema/src/index.ts"
      ],
      "@scanly/parsers": [
        "./packages/parsers/src/index.ts"
      ],
      "@scanly/benchmark": [
        "./packages/benchmark/src/index.ts"
      ],
      "@scanly/core": [
        "./packages/core/src/index.ts"
      ],
      "@scanly/core/*": [
        "./packages/core/src/*"
      ],
      "@scanly/browser": [
        "./packages/browser/src/index.ts"
      ],
      "@scanly/react": [
        "./packages/react/src/index.ts"
      ],
      "@scanly/engine-jsqr": [
        "./engines/jsqr/src/index.ts"
      ],
      "@scanly/engine-zxing-js": [
        "./engines/zxing-js/src/index.ts"
      ]
    },
    "esModuleInterop": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "apps/web-demo/.next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "scripts",
    "coverage",
    "playwright.config.ts",
    "vitest.config.ts"
  ]
}
