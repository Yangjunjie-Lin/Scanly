{
  "name": "@scanly/core",
  "version": "2.0.0-alpha.3",
  "description": "UI-independent Scanly barcode capture contracts, router, session, and QR pipeline",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./qr": {
      "types": "./dist/qr/index.d.ts",
      "import": "./dist/qr/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@scanly/parsers": "2.0.0-alpha.3",
    "@scanly/scenario-schema": "2.0.0-alpha.3"
  }
}
