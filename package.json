{
  "name": "scanly",
  "private": true,
  "version": "1.3.0",
  "license": "MIT",
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "benchmark": "tsx scripts/run-benchmark.ts",
    "benchmark:smoke": "tsx scripts/run-benchmark.ts --smoke --gate",
    "fixtures:generate": "tsx scripts/generate-fixtures.ts",
    "quality:gates": "tsx scripts/verify-quality-gates.ts",
    "check": "npm run quality:gates && npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "verify": "npm run check && npm run test:e2e && npm run benchmark:smoke"
  },
  "dependencies": {
    "@zxing/browser": "^0.2.1",
    "@zxing/library": "0.23.0",
    "jsqr": "^1.4.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "playwright": "^1.58.2",
    "qrcode": "^1.5.4",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "vitest": "^3.2.4"
  }
}
